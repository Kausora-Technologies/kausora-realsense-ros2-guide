# Kausora Technologies — Docker Environment Configuration
# Copy this file to .env and fill in your values:
#   cp docker/.env.example docker/.env

# ─── Camera Configuration ────────────────────────────────────────────────────

# Camera model to launch (d415 | d435 | d435i | d455 | l515 | t265)
CAMERA_MODEL=d435

# Camera serial number (leave empty to use first available camera)
# Find your serial: rs-enumerate-devices | grep "Serial Number"
CAMERA_SERIAL=

# For multi-camera setups
# CAMERA1_SERIAL=123456789
# CAMERA2_SERIAL=987654321

# ─── ROS2 Configuration ──────────────────────────────────────────────────────

# ROS Domain ID (0–101, must match other ROS2 nodes in your network)
ROS_DOMAIN_ID=0

# ─── Display Configuration ───────────────────────────────────────────────────

# X11 display for RViz / image_view (usually :0 or :1)
DISPLAY=:0
